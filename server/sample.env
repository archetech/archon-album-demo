# Album Server Configuration
# Copy to .env and customize

# Service Identity
ALBUM_NAME=les-troyens-2007
ALBUM_TITLE=Les Troyens
ALBUM_DOMAIN=album.archon.technology

# Archon Infrastructure
ARCHON_GATEKEEPER_URL=http://localhost:4224
ARCHON_WALLET_PASSPHRASE=change-me-to-a-secure-passphrase

# Wallet URL for QR codes (where users scan to authenticate)
ARCHON_WALLET_URL=https://wallet.archon.technology

# Server
PORT=4260
SESSION_SECRET=change-me-to-a-random-string

# Public URL (used for callbacks and QR codes)
PUBLIC_URL=http://localhost:4260

# IPFS Gateway for streaming
IPFS_GATEWAY=https://ipfs.io/ipfs

# Album Content CID (Les Troyens 2007)
ALBUM_CID=bafybeic4g2adodxjbpwp3nf5bnpry7bdzrzo5m7jmyfeddzmcb3h66y564

# Optional: Owner DID (admin access)
OWNER_DID=
